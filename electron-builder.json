{
  "appId": "me.zhaozunhong.holix-ai",
  "files": [
    "public/**/*",
    "package.json",
    ".holix/**/*",
    "!**/node_modules/react*/**",
    "!**/node_modules/lucide-react/**",
    "!**/node_modules/@radix-ui/**",
    "!**/node_modules/@lexical/**",
    "!**/node_modules/lexical/**",
    "!**/node_modules/framer-motion/**",
    "!**/node_modules/zustand/**",
    "!**/node_modules/immer/**",
    "!**/node_modules/@tanstack/**",
    "!**/node_modules/shiki/**",
    "!**/node_modules/@shikijs/**",
    "!**/node_modules/react-markdown/**",
    "!**/node_modules/react-virtuoso/**",
    "!**/node_modules/virtua/**",
    "!**/node_modules/sonner/**",
    "!**/node_modules/next-themes/**",
    "!**/node_modules/class-variance-authority/**",
    "!**/node_modules/clsx/**",
    "!**/node_modules/tailwind-merge/**",
    "!**/node_modules/tw-animate-css/**"
  ],
  "directories": {
    "buildResources": "./public"
  },
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*",
    "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
  ],
  "extraFiles": [
    {
      "from": "./drizzle",
      "to": "resources/drizzle",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "./skills",
      "to": "resources/builtin-skills",
      "filter": [
        "**/*.js",
        "**/*.json"
      ]
    }
  ],
  "asar": true,
  "productName": "Holix AI",
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "./public/favicon.icns",
    "artifactName": "holix-ai-${version}-${arch}.${ext}"
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 580,
      "height": 380
    }
  },
  "win": {
    "target": "nsis",
    "icon": "./public/favicon.ico",
    "artifactName": "holix-ai-setup-${version}-${arch}.exe"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "./public",
    "artifactName": "holix-ai-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "./public/favicon.ico",
    "uninstallerIcon": "./public/favicon.ico",
    "uninstallDisplayName": "Uninstall Holix AI",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Holix AI"
  },
  "npmRebuild": true,
  "buildDependenciesFromSource": true,
  "publish": [
    {
      "provider": "github",
      "owner": "zhaogongchengsi",
      "repo": "holix-ai",
      "private": false
    }
  ]
}
