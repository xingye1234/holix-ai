{
  "appId": "me.zhaozunhong.holix-ai",
  "files": [
    "public/**/*",
    "package.json",
    ".holix/**/*",
    "!node_modules/**",
    "node_modules/@holix/router/**/*",
    "node_modules/@holix/static/**/*",
    "node_modules/electron/**/*",
    "node_modules/drizzle-orm/**/*",
    "node_modules/nanoid/**/*",
    "node_modules/drizzle-orm/libsql/migrator/**/*",
    "node_modules/drizzle-orm/libsql/sqlite3/**/*",
    "node_modules/path/**/*",
    "node_modules/pathe/**/*",
    "node_modules/drizzle-orm/sqlite-core/**/*",
    "node_modules/lowdb/node/**/*",
    "node_modules/@tanstack/pacer/**/*",
    "node_modules/@langchain/anthropic/**/*",
    "node_modules/@langchain/openai/**/*",
    "node_modules/@langchain/google-genai/**/*",
    "node_modules/@langchain/ollama/**/*",
    "node_modules/@langchain/core/messages/**/*",
    "node_modules/zod/**/*"
  ],
  "artifactName": "holix-ai-${version}-${os}-${arch}",
  "directories": {
    "buildResources": "./public"
  },
  "extraFiles": [
    {
      "from": "./drizzle",
      "to": "resources/drizzle",
      "filter": [
        "**/*"
      ]
    }
  ],
  "asar": true,
  "productName": "Holix AI",
  "mac": {
    "target": "dmg",
    "icon": "./public/favicon.icns"
  },
  "win": {
    "target": "nsis",
    "icon": "./public/favicon.ico",
    "artifactName": "holix-ai-setup-${version}-${arch}.exe"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "./public",
    "artifactName": "holix-ai-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "./public/favicon.ico",
    "uninstallerIcon": "./public/favicon.ico",
    "uninstallDisplayName": "Uninstall Holix AI",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Holix AI"
  },
  "appImage": {
    "artifactName": "holix-ai-${version}-${arch}.AppImage"
  },
  "npmRebuild": false,
  "publish": [
    {
      "provider": "github",
      "owner": "zhaogongchengsi",
      "repo": "holix-ai",
      "private": false
    }
  ]
}
