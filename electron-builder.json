{
  "appId": "me.zhaozunhong.holix-ai",
  "files": [
    "node_modules/**/*",
    "public/**/*",
    "package.json",
    ".holix/**/*"
  ],
  "artifactName": "holix-ai-${version}-${os}-${arch}",
  "directories": {
    "buildResources": "./public"
  },
  "extraFiles": [
    {
      "from": "./drizzle",
      "to": "resources/drizzle",
      "filter": [
        "**/*"
      ]
    }
  ],
  "asar": true,
  "productName": "Holix AI",
  "mac": {
    "appId": "me.zhaozunhong.holix-ai",
    "target": "dmg",
    "icon": "./public/favicon.icns"
  },
  "dmg": {
    "icon": "./public/favicon.icns",
    "iconSize": 80,
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "target": "nsis",
    "icon": "./public/favicon.ico",
    "artifactName": "holix-ai-setup-${version}-${arch}.exe",
    "uninstallDisplayName": "${productName} Uninstall",
    "createDesktopShortcut": true
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "./public",
    "artifactName": "holix-ai-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "./public/favicon.ico",
    "uninstallerIcon": "./public/favicon.ico",
    "uninstallDisplayName": "Uninstall Holix AI",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Holix AI"
  },
  "appImage": {
    "artifactName": "holix-ai-${version}-${arch}.AppImage"
  },
  "npmRebuild": false,
  "publish": [
    {
      "provider": "github",
      "owner": "zhaogongchengsi",
      "repo": "holix-ai",
      "private": false
    }
  ]
}