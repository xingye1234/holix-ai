{
  "appId": "me.zhaozunhong.holix-ai",
  "files": [
    "public/**/*",
    "package.json",
    ".holix/**/*",
    "!node_modules/@antfu/eslint-config/**/*",
    "!node_modules/@biomejs/biome/**/*",
    "!node_modules/@tailwindcss/vite/**/*",
    "!node_modules/@tanstack/router-plugin/**/*",
    "!node_modules/@types/fs-extra/**/*",
    "!node_modules/@types/lodash/**/*",
    "!node_modules/@types/react/**/*",
    "!node_modules/@types/react-dom/**/*",
    "!node_modules/@vitejs/plugin-react/**/*",
    "!node_modules/concurrently/**/*",
    "!node_modules/drizzle-kit/**/*",
    "!node_modules/electron/**/*",
    "!node_modules/electron-builder/**/*",
    "!node_modules/eslint/**/*",
    "!node_modules/execa/**/*",
    "!node_modules/shadcn/**/*",
    "!node_modules/tailwindcss/**/*",
    "!node_modules/tsdown/**/*",
    "!node_modules/typescript/**/*",
    "!node_modules/vite/**/*"
  ],
  "artifactName": "holix-ai-${version}-${os}-${arch}",
  "directories": {
    "buildResources": "./public"
  },
  "extraFiles": [
    {
      "from": "./drizzle",
      "to": "resources/drizzle",
      "filter": [
        "**/*"
      ]
    }
  ],
  "asar": true,
  "productName": "Holix AI",
  "mac": {
    "target": "dmg",
    "icon": "./public/favicon.icns"
  },
  "win": {
    "target": "nsis",
    "icon": "./public/favicon.ico",
    "artifactName": "holix-ai-setup-${version}-${arch}.exe"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "./public",
    "artifactName": "holix-ai-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "./public/favicon.ico",
    "uninstallerIcon": "./public/favicon.ico",
    "uninstallDisplayName": "Uninstall Holix AI",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Holix AI"
  },
  "appImage": {
    "artifactName": "holix-ai-${version}-${arch}.AppImage"
  },
  "npmRebuild": false,
  "publish": [
    {
      "provider": "github",
      "owner": "zhaogongchengsi",
      "repo": "holix-ai",
      "private": false
    }
  ]
}
