{
  "name": "holix-ai",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.19.0",
  "description": "Holix AI - An AI-powered chat application",
  "author": "",
  "license": "MIT",
  "keywords": [],
  "main": "./.holix/main/main.mjs",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:vite": "vite",
    "dev:main": "tsdown --config-loader unrun -- --dev",
    "build:main": "tsdown --config-loader unrun",
    "build:vite": "vite build",
    "dev:app": "pnpm run dev:main && electron .",
    "build": "pnpm build:main && pnpm build:vite",
    "dev": "concurrently -k -n VITE,MAIN -c blue,green \"pnpm dev:vite\" \"pnpm dev:main\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:db": "drizzle-kit generate",
    "studio": "drizzle-kit studio",
    "lint": "eslint . --fix",
    "package": "electron-builder build -c ./electron-builder.json --publish never",
    "release": "pnpm build && pnpm package",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:windows": "electron-rebuild -f -w better-sqlite3 --arch=x64",
    "rebuild:mac": "electron-rebuild -f -w better-sqlite3 --arch=arm64",
    "test:skills": "vitest run -c vitest.skills.config.ts",
    "changelog": "node scripts/generate-changelog.js",
    "release-notes": "node scripts/generate-release-notes.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "dependencies": {
    "@holix/router": "^0.0.3",
    "@holix/static": "^0.0.6",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/anthropic": "^1.3.3",
    "@langchain/core": "^1.1.12",
    "@langchain/google-genai": "^2.1.3",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.1.0",
    "@langchain/openai": "^1.2.0",
    "@langchain/tavily": "^1.2.0",
    "@lexical/react": "^0.39.0",
    "@libsql/client": "^0.15.15",
    "@libsql/win32-x64-msvc": "^0.5.22",
